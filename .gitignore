# Ignore compiled shared libraries and native binaries
*.so
*.dll
*.dylib
*.class
/tmp/

# Whitelist native libraries packed in resources
!**/resources/native/**

# Ignore Maven build output directories
target/
**/target/

# Ignore developer configuration files and state properties
**/hexacloud.properties
**/*-state.properties

# Ignore code review reports
CODE_REVIEW.md

.agent